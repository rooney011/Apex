# =========================================================================
#  APEX repo .gitignore
# =========================================================================

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- FastF1 ----
# On-disk cache; rebuildable by re-running pulls
fastf1_cache/

# ---- Node / Next.js ----
node_modules/
.next/
.turbo/
.vercel/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# ---- Env files (never commit secrets) ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# ---- Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ---- Test coverage ----
coverage/
.nyc_output/

# ---- IDE / editor ----
.vscode/
.idea/
*.swp
*.swo
*.sublime-workspace
*.sublime-project

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini
*~

# ---- Misc local ----
*.local
.tmp/
.cache/
*.tgz
